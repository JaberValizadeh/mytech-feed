{
  "name": "technews-persian-server",
  "version": "1.0.0",
  "private": true,
  "description": "Backend for TechNews Persian: RSS aggregation + OpenAI pipeline + REST API",
  "type": "module",
  "scripts": {
    "aggregate": "tsx src/aggregate.ts",
    "dev": "tsx watch src/api.ts",
    "start": "node dist/api.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^6.42.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "allowScripts": {
    "esbuild@0.28.0": true,
    "fsevents@2.3.3": true
  }
}
