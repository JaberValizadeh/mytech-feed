# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# OpenAI model used for the AI pipeline.
# Default gpt-4o-mini is cheap/fast and good for high-volume aggregation.
# Switch to gpt-4o for higher-quality Persian output at higher cost.
OPENAI_MODEL=gpt-4o-mini

# REST API port
PORT=4000

# Max items to pull per source per aggregation run
MAX_ITEMS_PER_SOURCE=8

# Automatic refresh: the API re-aggregates fresh news on this cadence (hours)
# so the app shows new stories every day without running anything by hand.
# Already-translated articles are reused, so each run only pays for new stories.
REFRESH_INTERVAL_HOURS=12

# Set to 0 to disable auto-refresh (use manual `npm run aggregate` only).
AUTO_REFRESH=1

# How many articles to keep in the rolling feed (newest first).
MAX_STORED_ARTICLES=300
